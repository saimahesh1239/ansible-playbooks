---
- name: install apache2 and PHP
  hosts: all
  become: yes
  tasks:
    - name: install apache2
      ansible.builtin.apt:
        name: apache2
        state: present
        update_cache: yes
    - name: install apache2
      ansible.builtin.apt:
        name: php libapache2-mod-php
        state: present
        update_cache: yes
    - name: apache2 service restart
      ansible.builtin.service:
        name: apache2
        state: restarted
